{
  "name": "nsw-design-system-plone6",
  "version": "0.1.0",
  "description": "nsw-design-system-plone6: Volto add-on",
  "main": "src/index.js",
  "license": "MIT",
  "keywords": [
    "volto-addon",
    "volto",
    "plone",
    "react"
  ],
  "scripts": {
    "i18n": "rm -rf build/messages && NODE_ENV=production i18n --addon",
    "release": "release-it",
    "test:start-frontend": "make -f ../Makefile start-test-frontend",
    "test:start-backend": "make -f ../Makefile start-test-backend",
    "test": "yarn test:start-backend && yarn test:start-frontend && yarn cypress:run",
    "test:start-frontend-dev": "make -f ../Makefile start-test-frontend-dev",
    "test:dev": "yarn test:start-backend && yarn test:start-frontend-dev && yarn cypress:open",
    "cypress:open": "NODE_ENV=test cypress open",
    "cypress:run": "NODE_ENV=test cypress run"
  },
  "addons": [
    "@eeacms/volto-accordion-block",
    "@kitconcept/volto-blocks-grid"
  ],
  "dependencies": {
    "@eeacms/volto-accordion-block": "3.4.15",
    "@fontsource/public-sans": "4.5.5",
    "@kitconcept/volto-blocks-grid": "4.2.0",
    "@plone/scripts": "*",
    "material-icons": "1.10.8",
    "nsw-design-system": "3.1.0"
  },
  "peerDependencies": {
    "@plone/volto": "16.0.0-alpha.22"
  },
  "devDependencies": {
    "mrs-developer": "1.7.1",
    "release-it": "^15.0.0",
    "start-server-and-test": "1.14.0"
  }
}
